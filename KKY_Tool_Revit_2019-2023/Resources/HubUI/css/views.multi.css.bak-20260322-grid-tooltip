.multi-page,
.HubShell {
    display: flex;
    flex-direction: column;
    gap: 18px;
    color: var(--text-main);
    height: 100%;
    min-height: 0;
    overflow: hidden;
    flex: 1 1 auto;
}

.multi-page .feature-shell {
    height: 100%;
    overflow: hidden;
}

.multi-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
}

.multi-header h2 {
    margin: 0 0 6px;
}

.multi-layout,
.HubBody {
    display: flex;
    gap: 16px;
    align-items: stretch;
    min-width: 0;
    min-height: 0;
    flex: 1 1 auto;
    overflow: hidden;
}

.multi-left,
.multi-right,
.HubLeft,
.HubRight {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 0;
    min-width: 0;
}

.multi-right,
.HubRight {
    flex: 1 1 auto;
    overflow: auto;
    padding-right: 8px;
    box-sizing: border-box;
    overflow-x: hidden;
}

.multi-left,
.HubLeft {
    flex: 0 0 520px;
    min-width: 420px;
    max-width: 620px;
    height: 100%;
    overflow: hidden;
    border-right: 1px solid var(--border-soft);
    padding-right: 16px;
    box-sizing: border-box;
    overflow-x: hidden;
}

.HubLeftTop,
.HubLeftSelected {
    flex: 0 0 auto;
    min-height: 0;
}

.HubLeftRvt {
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
}

.left-sticky {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.HubRight,
.rvt-table-wrap {
    scrollbar-width: thin;
    scrollbar-color: var(--scrollbar-thumb) transparent;
}

.HubRight::-webkit-scrollbar,
.rvt-table-wrap::-webkit-scrollbar {
    width: 10px;
    height: 10px;
}

.HubRight::-webkit-scrollbar-track,
.rvt-table-wrap::-webkit-scrollbar-track {
    background: transparent;
}

.HubRight::-webkit-scrollbar-thumb,
.rvt-table-wrap::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 999px;
}

.multi-section {
    background: var(--surface-card);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.multi-section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
}

.multi-section-title h3 {
    white-space: nowrap;
}

.multi-section.is-hidden {
    display: none;
}

.group-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid var(--border-soft);
    background: var(--surface-card);
}

.group-filter__btn {
    border: 1px solid var(--border-soft);
    background: var(--surface-subtle);
    color: var(--text-main);
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease;
}

.group-filter__btn:hover {
    border-color: var(--accent);
}

.group-filter__btn.is-active {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
}

.multi-page .btn {
    height: 34px;
    padding: 0 14px;
    border-radius: 10px;
}

.multi-page .btn--primary {
    background: var(--accent);
    color: var(--accentText);
    border-color: var(--accent);
}

.multi-page .btn--secondary {
    background: var(--surface-card);
    color: var(--text-main);
    border-color: var(--border-soft);
}

.btn--ghost {
    background: transparent;
    color: var(--text);
    border-color: transparent;
}

.btn:not(:disabled):hover {
    border-color: var(--accent);
    transform: translateY(-1px);
}

.btn--primary:not(:disabled):hover {
    filter: brightness(1.05);
}

.btn--ghost:not(:disabled):hover {
    background: var(--panel2);
}

.feature-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 7px 10px;
    border-radius: 12px;
    border: 1px solid var(--border-soft);
    background: var(--panel2);
    min-height: 58px;
}

.feature-row.is-clickable {
    cursor: pointer;
}

.feature-row.is-clickable:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
    box-shadow: 0 14px 26px rgba(37, 99, 235, .08);
}

.feature-row.is-clickable:focus-visible {
    outline: none;
    border-color: color-mix(in srgb, var(--accent) 65%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent), 0 14px 26px rgba(37, 99, 235, .08);
}

.feature-row.is-active {
    border-color: color-mix(in srgb, var(--accent) 75%, transparent);
    background: var(--surface-note);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 45%, transparent), var(--shadow-accent-soft);
}

.feature-row__header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
}

.feature-toggle {
    width: 18px;
    height: 18px;
    accent-color: var(--accent);
    background-color: var(--surface-card);
    border-radius: 4px;
    border: 1px solid var(--border-soft);
}

.feature-toggle:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--focus-ring);
}

.feature-row.is-active .feature-toggle {
    border-color: color-mix(in srgb, var(--accent) 90%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
}

.feature-row__left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    flex: 1;
}

.feature-row__text {
    display: grid;
    gap: 4px;
    min-width: 0;
    flex: 1;
}

.feature-row__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
    height: 22px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    border: 1px solid var(--border-soft);
    background: var(--surface-panel);
    color: var(--text-soft);
    white-space: nowrap;
}

.feature-row--workflow .feature-row__summary {
    color: var(--text-soft);
}

.feature-row--workflow {
    gap: 8px;
    padding: 10px 12px;
    border-radius: 16px;
    border-color: var(--border-accent-soft);
    background: var(--surface-elevated);
    box-shadow: var(--shadow-soft);
}

.feature-row--workflow.is-clickable:hover {
    border-color: color-mix(in srgb, var(--accent) 62%, transparent);
    background: var(--surface-note);
}

.feature-row--workflow .feature-row__header {
    align-items: flex-start;
    gap: 12px;
}

.feature-row--workflow .feature-row__left {
    align-items: flex-start;
    gap: 10px;
}

.feature-row--workflow .feature-row__icon {
    height: 30px;
    min-width: 48px;
    padding: 0 12px;
    font-size: 0.86rem;
    background: var(--surface-note-strong);
    color: var(--accent);
    border-color: var(--border-accent-soft);
}

.feature-row--workflow .feature-row__text strong {
    font-size: 0.94rem;
    line-height: 1.35;
}

.feature-row--workflow .feature-row__text span {
    display: block;
    -webkit-line-clamp: initial;
    overflow: visible;
    text-overflow: initial;
    white-space: normal;
    line-height: 1.5;
}

.feature-row--workflow .feature-row__right {
    align-self: flex-start;
    flex-shrink: 0;
}

.feature-row--workflow .feature-row__right .chip {
    white-space: nowrap;
}

.feature-row--workflow .feature-row__summary {
    padding-left: 56px;
    font-size: 0.8rem;
    line-height: 1.45;
    white-space: normal;
    overflow: visible;
    text-overflow: initial;
}

.feature-row__left strong {
    display: block;
    font-size: 0.92rem;
    white-space: normal;
    line-height: 1.35;
    word-break: keep-all;
    overflow-wrap: break-word;
}

.feature-row__left span {
    font-size: 0.79rem;
    color: var(--text-soft);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.45;
}

.feature-row--connector-hero .feature-row__header {
    align-items: flex-start;
}

.feature-row--connector-hero .feature-row__left {
    align-items: flex-start;
}

.feature-row--connector-hero .feature-row__text {
    gap: 6px;
}

.feature-row--connector-hero .feature-row__text strong {
    font-size: 0.95rem;
    line-height: 1.38;
    word-break: keep-all;
    overflow-wrap: break-word;
}

.feature-row--connector-hero .feature-row__text span {
    overflow: visible;
    text-overflow: initial;
    display: block;
    -webkit-line-clamp: initial;
    line-height: 1.45;
    white-space: normal;
}

.feature-row__right {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: nowrap;
}

.feature-row__summary {
    font-size: 0.78rem;
    color: var(--text-soft);
    white-space: normal;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.45;
}

.feature-row__right .chip {
    font-weight: 600;
}

/* Compact density for the left-side feature lists. Utility becomes fully dense,
   while BQC keeps the connector hero slightly larger for scanability. */
.multi-section--utility,
.multi-section--bqc-hero {
    gap: 10px;
}

.multi-section--utility .feature-row,
.multi-section--bqc-hero .feature-row {
    gap: 4px;
    padding: 6px 8px;
    border-radius: 12px;
    min-height: 48px;
}

.multi-section--utility .feature-row__header,
.multi-section--bqc-hero .feature-row__header {
    gap: 8px;
}

.multi-section--utility .feature-row__left,
.multi-section--bqc-hero .feature-row__left {
    gap: 8px;
}

.multi-section--utility .feature-row__text,
.multi-section--bqc-hero .feature-row__text {
    gap: 2px;
}

.multi-section--utility .feature-row__icon,
.multi-section--bqc-hero .feature-row__icon {
    height: 20px;
    padding: 0 7px;
    font-size: 0.68rem;
}

.multi-section--utility .feature-row__left strong,
.multi-section--bqc-hero .feature-row__left strong {
    font-size: 0.88rem;
    line-height: 1.28;
}

.multi-section--utility .feature-row__left span,
.multi-section--bqc-hero .feature-row__left span {
    font-size: 0.76rem;
    line-height: 1.32;
    -webkit-line-clamp: 1;
}

.multi-section--utility .feature-row__summary,
.multi-section--bqc-hero .feature-row__summary {
    font-size: 0.74rem;
    line-height: 1.32;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.multi-section--utility .feature-row__right,
.multi-section--bqc-hero .feature-row__right {
    gap: 4px;
}

.multi-section--utility .feature-row__right .chip,
.multi-section--bqc-hero .feature-row__right .chip {
    padding: 3px 9px;
    font-size: 0.72rem;
}

.multi-section--utility .feature-row--workflow,
.multi-section--bqc-hero .feature-row--workflow {
    gap: 6px;
    padding: 7px 10px;
    border-radius: 14px;
}

.multi-section--utility .feature-row--workflow .feature-row__header,
.multi-section--bqc-hero .feature-row--workflow .feature-row__header {
    align-items: center;
}

.multi-section--utility .feature-row--workflow .feature-row__left,
.multi-section--bqc-hero .feature-row--workflow .feature-row__left {
    align-items: center;
    gap: 8px;
}

.multi-section--utility .feature-row--workflow .feature-row__icon,
.multi-section--bqc-hero .feature-row--workflow .feature-row__icon {
    height: 24px;
    min-width: 42px;
    padding: 0 10px;
    font-size: 0.78rem;
}

.multi-section--utility .feature-row--workflow .feature-row__text strong,
.multi-section--bqc-hero .feature-row--workflow .feature-row__text strong {
    font-size: 0.9rem;
    line-height: 1.25;
}

.multi-section--utility .feature-row--workflow .feature-row__text span,
.multi-section--bqc-hero .feature-row--workflow .feature-row__text span {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.32;
}

.multi-section--utility .feature-row--workflow .feature-row__summary,
.multi-section--bqc-hero .feature-row--workflow .feature-row__summary {
    padding-left: 50px;
}

.multi-section--bqc-hero .feature-row--connector-hero {
    gap: 8px;
    padding: 10px 12px;
    min-height: 60px;
}

.multi-section--bqc-hero .feature-row--connector-hero .feature-row__header,
.multi-section--bqc-hero .feature-row--connector-hero .feature-row__left {
    align-items: flex-start;
}

.multi-section--bqc-hero .feature-row--connector-hero .feature-row__icon {
    height: 28px;
    min-width: 46px;
    padding: 0 12px;
    font-size: 0.84rem;
}

.multi-section--bqc-hero .feature-row--connector-hero .feature-row__text {
    gap: 4px;
}

.multi-section--bqc-hero .feature-row--connector-hero .feature-row__text strong {
    font-size: 0.94rem;
    line-height: 1.32;
}

.multi-section--bqc-hero .feature-row--connector-hero .feature-row__text span {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.multi-section--bqc-hero .feature-row--connector-hero .feature-row__summary {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.chip.is-clickable {
    cursor: pointer;
}

.chip.is-clickable:hover {
    border-color: color-mix(in srgb, var(--accent) 70%, transparent);
}

.chip--off {
    background: var(--chipBg);
    color: var(--text-main);
    border-color: var(--chipBorder);
}

.chip--warn {
    background: color-mix(in srgb, var(--warning) 18%, transparent);
    color: color-mix(in srgb, var(--warning) 70%, var(--text-main));
    border-color: color-mix(in srgb, var(--warning) 45%, transparent);
}

.chip--ok {
    background: color-mix(in srgb, var(--success) 18%, transparent);
    color: color-mix(in srgb, var(--success) 70%, var(--text-main));
    border-color: color-mix(in srgb, var(--success) 45%, transparent);
}

.chip--result {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: color-mix(in srgb, var(--accent) 70%, var(--text-main));
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
}

.chip--info {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: color-mix(in srgb, var(--accent) 65%, var(--text-main));
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
}

.multi-config {
    display: none;
    padding: 12px;
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    background: var(--surface-subtle);
    gap: 10px;
}

.multi-config.is-open {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.settings-panel {
    border: none;
    padding: 0;
    margin: 0;
    background: transparent;
}

.multi-config .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.85rem;
}

.multi-config .field input,
.multi-config .field select,
.multi-config .field textarea {
    background: var(--panel2);
    border: 1px solid var(--border-soft);
    color: inherit;
    border-radius: 8px;
    padding: 6px 8px;
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.multi-config .field input::placeholder,
.multi-config .field textarea::placeholder {
    color: var(--text-soft);
}

.multi-config .field input:focus-visible,
.multi-config .field select:focus-visible,
.multi-config .field textarea:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--focus-ring);
}

.multi-config textarea {
    min-height: 58px;
    resize: vertical;
}

.floorinfo-config {
    width: 100%;
    min-width: 0;
}

.floorinfo-config__controls {
    grid-template-columns: minmax(0, 1fr);
    align-items: start;
}

.floorinfo-config__controls .field,
.floorinfo-config__rules,
.floorinfo-config__table {
    min-width: 0;
}

.floorinfo-config__controls .field input {
    width: 100%;
    box-sizing: border-box;
}

.floorinfo-config__control-note,
.floorinfo-config__warning {
    grid-column: 1 / -1;
}

.floorinfo-config__header {
    align-items: flex-start;
}

.floorinfo-config__table {
    min-height: 260px;
    max-height: 420px;
}

.floorinfo-config__table .paramprop-table {
    table-layout: fixed;
}

.floorinfo-config__table .paramprop-table th:nth-child(1),
.floorinfo-config__table .paramprop-table td:nth-child(1) {
    width: 96px;
    text-align: center;
}

.floorinfo-config__table .paramprop-table th:nth-child(2),
.floorinfo-config__table .paramprop-table td:nth-child(2) {
    width: 148px;
}

.floorinfo-config__table .paramprop-table th:nth-child(3),
.floorinfo-config__table .paramprop-table td:nth-child(3) {
    width: 148px;
}

.floorinfo-config__table .paramprop-table th:nth-child(4),
.floorinfo-config__table .paramprop-table td:nth-child(4) {
    width: 220px;
}

.floorinfo-config__table .paramprop-table tr.is-inactive td {
    opacity: 0.68;
}

.checklist {
    max-height: 180px;
    overflow: auto;
    padding-right: 4px;
    display: grid;
    gap: 6px;
}

.check-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
}

.check-item input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--accent);
}

.check-item input[type="checkbox"]:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--focus-ring);
    border-radius: 4px;
}

.group-common-mini {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--surface-panel);
    border-radius: 12px;
    padding: 12px;
    border: 1px solid var(--border-soft);
}

.group-common-mini__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
}

.group-common-mini__summary {
    font-size: 0.82rem;
    color: var(--text-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.multi-rvt-controls {
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
}

.familylink-search input {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--border-soft);
    background: var(--surface-card);
    color: var(--text-main);
    padding: 6px 10px;
}

.familylink-target-list {
    border-radius: 12px;
    border: 1px solid var(--border-soft);
    background: var(--surface-subtle);
    padding: 8px;
    max-height: 220px;
    overflow: auto;
    display: grid;
    gap: 6px;
}

.familylink-target-row {
    display: grid;
    grid-template-columns: 18px 1fr;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
}

.familylink-target-row span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.familylink-target-empty {
    text-align: center;
    color: var(--text-soft);
    padding: 12px;
}

[data-theme="light"] .modal .familylink-target-row,
.theme-light .modal .familylink-target-row {
    color: var(--text-main);
}

[data-theme="light"] .modal .familylink-target-row strong,
.theme-light .modal .familylink-target-row strong {
    color: var(--text-main);
}

[data-theme="light"] .modal .familylink-target-row small,
.theme-light .modal .familylink-target-row small {
    color: var(--text-muted);
}

.familylink-selected {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.familylink-selected-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-width: 0;
    scrollbar-gutter: stable;
}

.rvt-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.rvt-panel-title {
    display: flex;
    align-items: center;
    gap: 8px;
}

.rvt-panel-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    min-height: 0;
}

.rvt-panel {
    flex: 1;
    min-height: 0;
}

.rvt-panel-title h3 {
    margin: 0;
    white-space: nowrap;
}

.rvt-empty {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    justify-content: center;
    padding: 16px;
    text-align: center;
    border-radius: 12px;
    border: 1px dashed var(--border-soft);
    background: var(--surface-subtle);
}

.rvt-table-wrap {
    border-radius: 12px;
    border: 1px solid var(--border-soft);
    background: var(--surface-subtle);
    overflow: auto;
    flex: 1;
    min-height: 0;
    overscroll-behavior: contain;
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
}


.rvt-table-wrap thead th {
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--tableHeaderBg);
}

.multi-rvt-summary {
    font-size: 0.85rem;
