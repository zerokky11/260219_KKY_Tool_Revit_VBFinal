    padding: 16px 18px;
    border-radius: 16px;
    border: 1px solid var(--border-accent-soft);
    background: var(--surface-elevated);
    box-shadow: var(--shadow-soft);
}

.multi-action-card__head {
    grid-area: head;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
}

.multi-action-card__head strong {
    font-size: .95rem;
}

.multi-action-card__head span {
    font-size: .82rem;
    color: var(--text-soft);
    line-height: 1.45;
}

.multi-action-card__summary {
    grid-area: summary;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
}

.multi-action-card__progress {
    grid-area: progress;
}

.run-summary__meta {
    display: block;
    width: 100%;
    align-items: center;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid var(--border-accent-soft);
    background: var(--surface-help);
    color: var(--text-main);
    font-size: .78rem;
    line-height: 1.45;
    white-space: normal;
}

.multi-action-card__actions {
    grid-area: actions;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
}

.multi-action-card__buttons {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 8px;
    min-width: 0;
}

.multi-action-card__buttons .btn {
    min-width: 0;
    min-height: 34px;
    justify-content: center;
}

.multi-action-card__buttons .btn--action-main {
    width: 138px;
    flex: 0 0 138px;
}

.multi-action-card__extras {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    min-width: 0;
}

.multi-action-card__extras .btn--settings-inline {
    min-height: 34px;
}

.multi-action-stack__note {
    font-size: .78rem;
    color: var(--text-soft);
    line-height: 1.45;
    padding: 0;
    min-width: 0;
    overflow-wrap: anywhere;
}

.multi-action-card__actions .btn--multi {
    background: linear-gradient(135deg, color-mix(in srgb, var(--success) 55%, #0f766e), color-mix(in srgb, var(--success) 78%, var(--accent)));
    color: var(--accentText);
    border-color: color-mix(in srgb, var(--success) 45%, var(--border-soft));
    box-shadow: var(--shadow-accent-soft);
}

.multi-action-card__actions .btn--multi:hover {
    border-color: color-mix(in srgb, var(--success) 55%, var(--border-soft));
    filter: brightness(1.04);
}

.multi-action-card__actions .btn--recent {
    background: linear-gradient(135deg, var(--accent), var(--accent-strong));
    color: var(--accentText);
    border-color: transparent;
}

.group-common-mini__summary--chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
}

.multi-side-card__top {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: start;
}

.multi-side-card__head {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    width: 100%;
}

.multi-side-card__head h3 {
    margin: 0;
}

.multi-side-card__toolset {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 120px;
}

.multi-side-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
}

.multi-side-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px;
    border-radius: 14px;
    border: 1px solid var(--border-soft);
    background: var(--surface-subtle);
}

.multi-side-stat__label {
    font-size: .76rem;
    color: var(--text-soft);
}

.multi-side-stat__value {
    font-size: .95rem;
    color: var(--text-main);
}

.multi-condition-list,
.multi-recent-list {
    margin: 0;
    padding-left: 18px;
    display: grid;
    gap: 8px;
    color: var(--text-main);
    font-size: .84rem;
    line-height: 1.45;
}

.multi-recent-caption {
    font-size: .82rem;
    color: var(--text-soft);
}

.multi-side-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.multi-side-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    width: 100%;
}

.multi-side-card--launcher {
    cursor: pointer;
}

.multi-side-card--launcher:hover {
    border-color: color-mix(in srgb, var(--accent) 36%, var(--border-soft));
    box-shadow: 0 12px 24px rgba(37, 99, 235, .08);
}

.multi-side-card--launcher:focus-visible {
    outline: none;
    border-color: color-mix(in srgb, var(--accent) 52%, var(--border-soft));
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent), 0 12px 24px rgba(37, 99, 235, .08);
}

.selected-panel--sidebar .selected-table th,
.selected-panel--sidebar .selected-table td {
    padding: 7px 8px;
}

.multi-recent-hint {
    font-size: .78rem;
    color: var(--text-soft);
    line-height: 1.45;
}

.multi-recent-launcher {
    display: grid;
    gap: 6px;
    padding: 14px;
    border-radius: 14px;
    border: 1px solid var(--border-accent-soft);
    background: var(--surface-help);
}

.multi-recent-launcher strong {
    font-size: .92rem;
    color: var(--text-main);
}

.multi-recent-launcher span {
    font-size: .82rem;
    color: var(--text-soft);
    line-height: 1.5;
}

.multi-recent-table {
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    background: var(--surface-help);
    overflow: auto;
    min-height: 0;
}

.multi-side-card {
    display: grid;
    gap: 14px;
    min-width: 0;
}

.multi-recent-table table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
}

.multi-recent-table th,
.multi-recent-table td {
    padding: 8px 10px;
    border-bottom: 1px solid var(--border-soft);
    text-align: left;
    font-size: .83rem;
    vertical-align: top;
}

.multi-recent-table thead th {
    position: sticky;
    top: 0;
    background: var(--tableHeaderBg);
    color: var(--tableHeaderText);
    font-weight: 600;
    white-space: nowrap;
}

.multi-recent-table__file {
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    line-height: 1.45;
}

.multi-recent-table__empty {
    padding: 16px;
    color: var(--text-soft);
    text-align: center;
    font-size: .82rem;
}

.rvt-expand-feature-list {
    display: grid;
    gap: 8px;
}

.rvt-expand-feature-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: start;
    gap: 8px;
    padding: 10px 12px;
    border-radius: 12px;
    background: var(--surface-elevated);
    border: 1px solid var(--border-soft);
    overflow: hidden;
}

.rvt-expand-feature-item__text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
}

.rvt-expand-feature-item__meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    min-width: 0;
}

.rvt-expand-feature-item__text strong {
    font-size: .86rem;
    white-space: normal;
    overflow: visible;
    text-overflow: initial;
    line-height: 1.35;
    word-break: keep-all;
}

.rvt-expand-feature-item__text span {
    font-size: .76rem;
    color: var(--text-soft);
    white-space: normal;
    overflow: hidden;
    text-overflow: initial;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.4;
}

.rvt-expand-feature-item .status-chip,
.rvt-expand-feature-item .chip {
    justify-self: start;
    align-self: flex-start;
    max-width: 100%;
    white-space: nowrap;
    flex-shrink: 0;
}

.rvt-expand-feature-empty {
    padding: 14px 12px;
    border-radius: 12px;
    border: 1px dashed var(--border-soft);
    color: var(--text-soft);
    background: var(--surface-empty);
    font-size: .82rem;
}

.multi-recent-table--modal {
    max-height: 280px;
}

.selected-panel--inline {
    margin-top: 0;
}

.multi-sidebar-stack {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
}

.multi-sidebar-stack--sticky {
    position: sticky;
    top: 0;
    max-height: calc(100vh - 150px);
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-gutter: stable;
    padding-right: 6px;
    padding-bottom: 10px;
}

.multi-sidebar-stack--sticky::-webkit-scrollbar {
    width: 10px;
}

.multi-sidebar-stack--sticky::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 999px;
}

.rvt-expand-footer {
    justify-content: space-between;
    align-items: center;
}

.rvt-expand-footer__summary {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.rvt-expand-footer__summary strong {
    font-size: .92rem;
}

.rvt-expand-footer__summary span {
    font-size: .8rem;
    color: var(--text-soft);
}

.rvt-expand-footer__actions {
    display: flex;
    align-items: center;
    gap: 8px;
}

@media (max-width: 960px) {
    .run-bar {
        grid-template-columns: 1fr;
    }

    .multi-layout--bqc,
    .multi-layout--utility {
        grid-template-columns: 1fr;
    }

    .multi-layout--bqc .multi-workspace--main,
    .multi-layout--utility .multi-workspace--main {
        overflow: visible;
        padding-right: 0;
    }

    .multi-section--bqc-hero {
        flex: 0 0 auto;
        min-height: auto;
        overflow: visible;
    }

    .multi-sidebar-stack--sticky {
        position: static;
        max-height: none;
        overflow: visible;
        padding-right: 0;
    }

    .multi-action-card {
        grid-template-columns: 1fr;
        grid-template-areas:
            "head"
            "summary"
            "progress"
            "actions";
    }

    .multi-side-stats {
        grid-template-columns: 1fr;
    }

    .multi-side-card__top {
        grid-template-columns: 1fr;
    }

    .multi-side-card__toolset {
        min-width: 0;
        width: 100%;
    }

    .rvt-expand-footer {
        flex-direction: column;
        align-items: stretch;
    }

    .rvt-expand-footer__actions {
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .feature-row__right {
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .feature-row--workflow .feature-row__summary {
        padding-left: 0;
    }

    .modal__body {
        grid-template-columns: 1fr;
    }

    .rvt-expand-panel {
        grid-template-columns: 1fr;
    }

    .rvt-expand-section--list {
        border-right: 0;
    border-bottom: 1px solid var(--border-soft);
    }
}
