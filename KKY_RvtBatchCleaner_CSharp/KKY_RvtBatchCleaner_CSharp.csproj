<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{4D7A88B1-8287-4B80-932E-1A4BAAB0A8D9}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>KKY_Tool_Revit</RootNamespace>
    <AssemblyName>KKY_RvtBatchCleaner_CSharp</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
    <Prefer32Bit>false</Prefer32Bit>
    <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
  </PropertyGroup>

  <PropertyGroup>
    <RevitYear Condition=" '$(RevitYear)' == '' ">2019</RevitYear>
    <RevitApiDir Condition=" '$(RevitApiDir)' == '' ">$(ProgramFiles)\Autodesk\Revit $(RevitYear)</RevitApiDir>
    <RevitAddinsDir Condition=" '$(RevitAddinsDir)' == '' ">$(AppData)\Autodesk\Revit\Addins\$(RevitYear)</RevitAddinsDir>
    <DeployToRevitAddins Condition=" '$(DeployToRevitAddins)' == '' ">true</DeployToRevitAddins>
    <AddInId>54DFF7AD-7194-4E88-8D9D-9F6A3C08C8A7</AddInId>
    <AddInFullClassName>KKY_Tool_Revit.App</AddInFullClassName>
    <VendorId>KKY</VendorId>
    <VendorDescription>KKY RVT Batch Cleaner</VendorDescription>
    <OutputPath>bin\$(Configuration)\Rvt$(RevitYear)\</OutputPath>
    <IntermediateOutputPath>obj\$(Configuration)\Rvt$(RevitYear)\</IntermediateOutputPath>
    <AutoGeneratedAddinFile>$(TargetDir)$(AssemblyName).addin</AutoGeneratedAddinFile>
    <DeployedAddinFile>$(RevitAddinsDir)\$(AssemblyName).addin</DeployedAddinFile>
    <DeployedAssemblyFile>$(RevitAddinsDir)\$(AssemblyName).dll</DeployedAssemblyFile>
    <DeployedPdbFile>$(RevitAddinsDir)\$(AssemblyName).pdb</DeployedPdbFile>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="RevitAPI">
      <HintPath>$(RevitApiDir)\RevitAPI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>$(RevitApiDir)\RevitAPIUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Data" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Xml.Linq" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="App.cs" />
    <Compile Include="Commands\CmdOpenBatchCleaner.cs" />
    <Compile Include="Models\BatchCleanSettings.cs" />
    <Compile Include="Models\BatchCleanResult.cs" />
    <Compile Include="Models\BatchPrepareSession.cs" />
    <Compile Include="Models\PreparedDocumentEntry.cs" />
    <Compile Include="Models\PurgeBatchProgressSnapshot.cs" />
    <Compile Include="Models\ElementParameterUpdateSettings.cs" />
    <Compile Include="Models\ViewFilterProfile.cs" />
    <Compile Include="Models\ViewParameterAssignment.cs" />
    <Compile Include="Services\BatchCleanService.cs" />
    <Compile Include="Services\RevitViewFilterProfileService.cs" />
    <Compile Include="Services\LegacyPurgeService.cs" />
    <Compile Include="Services\PurgeUiBatchService.cs" />
    <Compile Include="Services\VerificationService.cs" />
    <Compile Include="Services\ModelParameterExtractionService.cs" />
    <Compile Include="Services\PurgeProgressWindowHost.cs" />
    <Compile Include="Services\TransactionFailureSwallower.cs" />
    <Compile Include="UI\BatchCleanerForm.cs" />
    <Compile Include="UI\ElementParameterUpdateConfigForm.cs" />
    <Compile Include="UI\ModelParameterExtractionForm.cs" />
    <Compile Include="UI\PurgeProgressForm.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="KKY_RvtBatchCleaner_CSharp.addin" />
    <None Include="README.md" />
    <None Include="build_revit.bat" />
  </ItemGroup>

  <ItemGroup>
    <_AddinXmlLine Include="&lt;?xml version=&quot;1.0&quot; encoding=&quot;utf-8&quot; standalone=&quot;no&quot;?&gt;" />
    <_AddinXmlLine Include="&lt;RevitAddIns&gt;" />
    <_AddinXmlLine Include="  &lt;AddIn Type=&quot;Application&quot;&gt;" />
    <_AddinXmlLine Include="    &lt;Name&gt;$(AssemblyName)&lt;/Name&gt;" />
    <_AddinXmlLine Include="    &lt;Assembly&gt;$(DeployedAssemblyFile)&lt;/Assembly&gt;" />
    <_AddinXmlLine Include="    &lt;AddInId&gt;$(AddInId)&lt;/AddInId&gt;" />
    <_AddinXmlLine Include="    &lt;FullClassName&gt;$(AddInFullClassName)&lt;/FullClassName&gt;" />
    <_AddinXmlLine Include="    &lt;VendorId&gt;$(VendorId)&lt;/VendorId&gt;" />
    <_AddinXmlLine Include="    &lt;VendorDescription&gt;$(VendorDescription)&lt;/VendorDescription&gt;" />
    <_AddinXmlLine Include="  &lt;/AddIn&gt;" />
    <_AddinXmlLine Include="&lt;/RevitAddIns&gt;" />
  </ItemGroup>

  <Target Name="ValidateRevitApiReferences" BeforeTargets="BeforeBuild">
    <Error Condition="!Exists('$(RevitApiDir)\RevitAPI.dll')"
           Text="RevitAPI.dll not found at '$(RevitApiDir)'. Set RevitApiDir or RevitYear. Example: /p:RevitYear=2023 or /p:RevitApiDir=C:\Program Files\Autodesk\Revit 2023" />
    <Error Condition="!Exists('$(RevitApiDir)\RevitAPIUI.dll')"
           Text="RevitAPIUI.dll not found at '$(RevitApiDir)'. Set RevitApiDir or RevitYear. Example: /p:RevitYear=2023 or /p:RevitApiDir=C:\Program Files\Autodesk\Revit 2023" />
  </Target>

  <Target Name="DeployRevitAddin" AfterTargets="Build">
    <WriteLinesToFile File="$(AutoGeneratedAddinFile)"
                      Lines="@(_AddinXmlLine)"
                      Overwrite="true"
                      Encoding="UTF-8" />

    <MakeDir Directories="$(RevitAddinsDir)" Condition=" '$(DeployToRevitAddins)' == 'true' " />

    <Copy SourceFiles="$(TargetPath)"
          DestinationFiles="$(DeployedAssemblyFile)"
          SkipUnchangedFiles="true"
          Condition=" '$(DeployToRevitAddins)' == 'true' " />

    <Copy SourceFiles="$(TargetDir)$(AssemblyName).pdb"
          DestinationFiles="$(DeployedPdbFile)"
          SkipUnchangedFiles="true"
          Condition=" '$(DeployToRevitAddins)' == 'true' and Exists('$(TargetDir)$(AssemblyName).pdb') " />

    <Copy SourceFiles="$(AutoGeneratedAddinFile)"
          DestinationFiles="$(DeployedAddinFile)"
          SkipUnchangedFiles="true"
          Condition=" '$(DeployToRevitAddins)' == 'true' " />

    <Message Importance="high" Text="RevitYear=$(RevitYear)" />
    <Message Importance="high" Text="RevitApiDir=$(RevitApiDir)" />
    <Message Importance="high" Text="Revit add-in deployed to $(RevitAddinsDir)" Condition=" '$(DeployToRevitAddins)' == 'true' " />
    <Message Importance="high" Text="Generated add-in manifest: $(AutoGeneratedAddinFile)" />
  </Target>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
